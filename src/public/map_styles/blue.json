{
    "version": 8,
    "name": "TrunkInsight Blue Dashboard",
    "metadata": {
        "description": "科技蓝主题地图 - 与 TrunkInsight 仪表盘 UI 配色协调"
    },
    "center": [116.38, 39.9],
    "zoom": 3,
    "bearing": 0,
    "pitch": 0,
    "sprite": "/sprites/ofm",
    "sources": {
        "openmaptiles": {
            "type": "vector",
            "url": "https://tiles.openfreemap.org/planet"
        }
    },
    "sky": {
        "sky-color": "#001529",
        "horizon-color": "#0a4a8a",
        "fog-color": "#001529",
        "fog-ground-blend": 0.3,
        "horizon-fog-blend": 0.5,
        "sky-horizon-blend": 0.4,
        "atmosphere-blend": 1.0
    },
    "layers": [
        {
            "id": "background",
            "type": "background",
            "paint": {
                "background-color": "#001529"
            }
        },
        {
            "id": "water",
            "type": "fill",
            "source": "openmaptiles",
            "source-layer": "water",
            "paint": {
                "fill-color": "#00243d",
                "fill-opacity": 1
            }
        },
        {
            "id": "waterway",
            "type": "line",
            "source": "openmaptiles",
            "source-layer": "waterway",
            "paint": {
                "line-color": "#00365a",
                "line-width": [
                    "interpolate",
                    ["linear"],
                    ["zoom"],
                    8,
                    0.5,
                    14,
                    2
                ]
            }
        },
        {
            "id": "landcover-glacier",
            "type": "fill",
            "source": "openmaptiles",
            "source-layer": "landcover",
            "filter": ["==", ["get", "class"], "ice"],
            "paint": {
                "fill-color": "#1a4a6a",
                "fill-opacity": 0.5
            }
        },
        {
            "id": "landcover-wood",
            "type": "fill",
            "source": "openmaptiles",
            "source-layer": "landcover",
            "filter": ["==", ["get", "class"], "wood"],
            "paint": {
                "fill-color": "#0a3a4a",
                "fill-opacity": 0.3
            }
        },
        {
            "id": "landcover-grass",
            "type": "fill",
            "source": "openmaptiles",
            "source-layer": "landcover",
            "filter": ["==", ["get", "class"], "grass"],
            "paint": {
                "fill-color": "#0a3545",
                "fill-opacity": 0.25
            }
        },
        {
            "id": "landuse-residential",
            "type": "fill",
            "source": "openmaptiles",
            "source-layer": "landuse",
            "filter": ["==", ["get", "class"], "residential"],
            "paint": {
                "fill-color": "#002b5c",
                "fill-opacity": 0.4
            }
        },
        {
            "id": "landuse-commercial",
            "type": "fill",
            "source": "openmaptiles",
            "source-layer": "landuse",
            "filter": ["==", ["get", "class"], "commercial"],
            "paint": {
                "fill-color": "#003366",
                "fill-opacity": 0.35
            }
        },
        {
            "id": "landuse-industrial",
            "type": "fill",
            "source": "openmaptiles",
            "source-layer": "landuse",
            "filter": ["==", ["get", "class"], "industrial"],
            "paint": {
                "fill-color": "#002952",
                "fill-opacity": 0.35
            }
        },
        {
            "id": "park",
            "type": "fill",
            "source": "openmaptiles",
            "source-layer": "park",
            "paint": {
                "fill-color": "#0a4050",
                "fill-opacity": 0.4
            }
        },
        {
            "id": "boundary-country",
            "type": "line",
            "source": "openmaptiles",
            "source-layer": "boundary",
            "filter": ["==", ["get", "admin_level"], 2],
            "paint": {
                "line-color": "#1890ff",
                "line-width": [
                    "interpolate",
                    ["linear"],
                    ["zoom"],
                    0,
                    0.5,
                    5,
                    1.5,
                    10,
                    2
                ],
                "line-opacity": 0.8
            }
        },
        {
            "id": "boundary-state",
            "type": "line",
            "source": "openmaptiles",
            "source-layer": "boundary",
            "filter": ["==", ["get", "admin_level"], 4],
            "minzoom": 3,
            "paint": {
                "line-color": "#4da6ff",
                "line-width": 0.8,
                "line-dasharray": [3, 2],
                "line-opacity": 0.5
            }
        },
        {
            "id": "road-motorway",
            "type": "line",
            "source": "openmaptiles",
            "source-layer": "transportation",
            "filter": ["==", ["get", "class"], "motorway"],
            "paint": {
                "line-color": "#1890ff",
                "line-width": [
                    "interpolate",
                    ["exponential", 1.5],
                    ["zoom"],
                    5,
                    0.5,
                    12,
                    3,
                    18,
                    15
                ],
                "line-opacity": 0.7
            }
        },
        {
            "id": "road-trunk",
            "type": "line",
            "source": "openmaptiles",
            "source-layer": "transportation",
            "filter": ["==", ["get", "class"], "trunk"],
            "paint": {
                "line-color": "#40a9ff",
                "line-width": [
                    "interpolate",
                    ["exponential", 1.5],
                    ["zoom"],
                    5,
                    0.3,
                    12,
                    2,
                    18,
                    10
                ],
                "line-opacity": 0.65
            }
        },
        {
            "id": "road-primary",
            "type": "line",
            "source": "openmaptiles",
            "source-layer": "transportation",
            "filter": ["==", ["get", "class"], "primary"],
            "paint": {
                "line-color": "#69c0ff",
                "line-width": [
                    "interpolate",
                    ["exponential", 1.5],
                    ["zoom"],
                    8,
                    0.5,
                    14,
                    2,
                    18,
                    8
                ],
                "line-opacity": 0.6
            }
        },
        {
            "id": "road-secondary",
            "type": "line",
            "source": "openmaptiles",
            "source-layer": "transportation",
            "filter": ["==", ["get", "class"], "secondary"],
            "minzoom": 8,
            "paint": {
                "line-color": "#91d5ff",
                "line-width": [
                    "interpolate",
                    ["exponential", 1.5],
                    ["zoom"],
                    8,
                    0.3,
                    14,
                    1.5,
                    18,
                    6
                ],
                "line-opacity": 0.5
            }
        },
        {
            "id": "road-tertiary",
            "type": "line",
            "source": "openmaptiles",
            "source-layer": "transportation",
            "filter": ["==", ["get", "class"], "tertiary"],
            "minzoom": 10,
            "paint": {
                "line-color": "#b5e3ff",
                "line-width": [
                    "interpolate",
                    ["exponential", 1.5],
                    ["zoom"],
                    10,
                    0.2,
                    14,
                    1,
                    18,
                    4
                ],
                "line-opacity": 0.45
            }
        },
        {
            "id": "road-street",
            "type": "line",
            "source": "openmaptiles",
            "source-layer": "transportation",
            "filter": [
                "in",
                ["get", "class"],
                ["literal", ["minor", "service", "track"]]
            ],
            "minzoom": 12,
            "paint": {
                "line-color": "#cceeff",
                "line-width": [
                    "interpolate",
                    ["exponential", 1.5],
                    ["zoom"],
                    12,
                    0.2,
                    16,
                    1,
                    18,
                    3
                ],
                "line-opacity": 0.4
            }
        },
        {
            "id": "rail",
            "type": "line",
            "source": "openmaptiles",
            "source-layer": "transportation",
            "filter": ["==", ["get", "class"], "rail"],
            "minzoom": 8,
            "paint": {
                "line-color": "#5ab8ff",
                "line-width": 1,
                "line-dasharray": [4, 2],
                "line-opacity": 0.4
            }
        },
        {
            "id": "building-3d",
            "type": "fill-extrusion",
            "source": "openmaptiles",
            "source-layer": "building",
            "minzoom": 14,
            "paint": {
                "fill-extrusion-color": [
                    "interpolate",
                    ["linear"],
                    ["zoom"],
                    14,
                    "#002b5c",
                    16,
                    "#003d7a",
                    18,
                    "#004d99"
                ],
                "fill-extrusion-height": [
                    "interpolate",
                    ["linear"],
                    ["zoom"],
                    14,
                    0,
                    15,
                    ["*", ["get", "render_height"], 0.5],
                    16,
                    ["get", "render_height"]
                ],
                "fill-extrusion-base": [
                    "case",
                    [">=", ["get", "render_min_height"], 0],
                    ["get", "render_min_height"],
                    0
                ],
                "fill-extrusion-opacity": [
                    "interpolate",
                    ["linear"],
                    ["zoom"],
                    14,
                    0.5,
                    16,
                    0.85
                ],
                "fill-extrusion-vertical-gradient": true
            }
        },
        {
            "id": "building-glow",
            "type": "line",
            "source": "openmaptiles",
            "source-layer": "building",
            "minzoom": 15,
            "paint": {
                "line-color": "#1890ff",
                "line-width": [
                    "interpolate",
                    ["linear"],
                    ["zoom"],
                    15,
                    0.3,
                    18,
                    1.2
                ],
                "line-opacity": [
                    "interpolate",
                    ["linear"],
                    ["zoom"],
                    15,
                    0.2,
                    18,
                    0.5
                ],
                "line-blur": 2
            }
        },
        {
            "id": "poi_label",
            "type": "symbol",
            "source": "openmaptiles",
            "source-layer": "poi",
            "minzoom": 13,
            "filter": ["all", ["==", "$type", "Point"], ["==", "rank", 1]],
            "layout": {
                "text-size": 12,
                "icon-image": "{class}",
                "text-offset": [0, 1.2],
                "text-anchor": "top",
                "text-field": "{name:latin}\n{name:nonlatin}",
                "icon-size": 1,
                "text-max-width": 8
            },
            "paint": {
                "text-color": "#b5e3ff",
                "text-halo-width": 1.5,
                "text-halo-color": "#001529"
            }
        },
        {
            "id": "road_major_label",
            "type": "symbol",
            "source": "openmaptiles",
            "source-layer": "transportation_name",
            "filter": [
                "all",
                ["==", "$type", "LineString"],
                ["!has", "name:en"]
            ],
            "layout": {
                "symbol-placement": "line",
                "text-field": "{name:latin} {name:nonlatin}",
                "text-letter-spacing": 0.1,
                "text-rotation-alignment": "map",
                "text-size": {
                    "base": 1.4,
                    "stops": [
