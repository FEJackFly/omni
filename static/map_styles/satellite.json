{
    "version": 8,
    "name": "TrunkInsight Satellite",
    "metadata": {
        "description": "基于 ESRI World Imagery 的卫星图底图，叠加 OpenFreeMap 道路标注，支持 3D 地形"
    },
    "sprite": "https://tiles.openfreemap.org/sprites/ofm_f384/ofm",
    "sources": {
        "openmaptiles": {
            "type": "vector",
            "url": "https://tiles.openfreemap.org/planet"
        },
        "esri-satellite": {
            "type": "raster",
            "tiles": [
                "https://server.arcgisonline.com/ArcGIS/rest/services/World_Imagery/MapServer/tile/{z}/{y}/{x}"
            ],
            "tileSize": 256,
            "maxzoom": 18,
            "attribution": "© Esri"
        },
        "terrain": {
            "type": "raster-dem",
            "tiles": [
                "https://s3.amazonaws.com/elevation-tiles-prod/terrarium/{z}/{x}/{y}.png"
            ],
            "tileSize": 256,
            "maxzoom": 15,
            "encoding": "terrarium"
        },
        "hillshade-source": {
            "type": "raster-dem",
            "tiles": [
                "https://s3.amazonaws.com/elevation-tiles-prod/terrarium/{z}/{x}/{y}.png"
            ],
            "tileSize": 256,
            "maxzoom": 15,
            "encoding": "terrarium"
        }
    },
    "sky": {
        "sky-color": "#050510",
        "horizon-color": "#1a3a6a",
        "fog-color": "#0a0a1a",
        "fog-ground-blend": 0.3,
        "horizon-fog-blend": 0.5,
        "sky-horizon-blend": 0.3,
        "atmosphere-blend": 1
    },
    "layers": [
        {
            "id": "background",
            "type": "background",
            "paint": {
                "background-color": "#050510"
            }
        },
        {
            "id": "satellite",
            "type": "raster",
            "source": "esri-satellite",
            "paint": {
                "raster-opacity": 1,
                "raster-saturation": 0.1,
                "raster-brightness-min": 0.05
            }
        },
        {
            "id": "hillshade",
            "type": "hillshade",
            "source": "hillshade-source",
            "paint": {
                "hillshade-exaggeration": 0.5,
                "hillshade-shadow-color": "#000000",
                "hillshade-highlight-color": "#ffffff",
                "hillshade-accent-color": "#333333"
            }
        },
        {
            "id": "boundary-country",
            "type": "line",
            "source": "openmaptiles",
            "source-layer": "boundary",
            "filter": ["==", ["get", "admin_level"], 2],
            "paint": {
                "line-color": "#ffcc00",
                "line-width": [
                    "interpolate",
                    ["linear"],
                    ["zoom"],
                    0,
                    0.5,
                    5,
                    1.5,
                    10,
                    2
                ],
                "line-opacity": 0.9
            }
        },
        {
            "id": "boundary-state",
            "type": "line",
            "source": "openmaptiles",
            "source-layer": "boundary",
            "filter": ["==", ["get", "admin_level"], 4],
            "minzoom": 3,
            "paint": {
                "line-color": "#ffcc00",
                "line-width": 0.8,
                "line-dasharray": [3, 2],
                "line-opacity": 0.6
            }
        },
        {
            "id": "road-motorway",
            "type": "line",
            "source": "openmaptiles",
            "source-layer": "transportation",
            "filter": ["==", ["get", "class"], "motorway"],
            "minzoom": 6,
            "paint": {
                "line-color": "#ff8c00",
                "line-width": [
                    "interpolate",
                    ["exponential", 1.5],
                    ["zoom"],
                    5,
                    0.5,
                    12,
                    3,
                    18,
                    15
                ],
                "line-opacity": 0.75
            }
        },
        {
            "id": "road-trunk",
            "type": "line",
            "source": "openmaptiles",
            "source-layer": "transportation",
            "filter": ["==", ["get", "class"], "trunk"],
            "minzoom": 8,
            "paint": {
                "line-color": "#ffa500",
                "line-width": [
                    "interpolate",
                    ["exponential", 1.5],
                    ["zoom"],
                    5,
                    0.3,
                    12,
                    2,
                    18,
                    10
                ],
                "line-opacity": 0.7
            }
        },
        {
            "id": "road-primary",
            "type": "line",
            "source": "openmaptiles",
            "source-layer": "transportation",
            "filter": ["==", ["get", "class"], "primary"],
            "minzoom": 10,
            "paint": {
                "line-color": "#ffdd44",
                "line-width": [
                    "interpolate",
                    ["exponential", 1.5],
                    ["zoom"],
                    8,
                    0.5,
                    14,
                    2,
                    18,
                    8
                ],
                "line-opacity": 0.65
            }
        },
        {
            "id": "road-secondary",
            "type": "line",
            "source": "openmaptiles",
            "source-layer": "transportation",
            "filter": ["==", ["get", "class"], "secondary"],
            "minzoom": 8,
            "paint": {
                "line-color": "#ffee66",
                "line-width": [
                    "interpolate",
                    ["exponential", 1.5],
                    ["zoom"],
                    8,
                    0.3,
                    14,
                    1.5,
                    18,
                    6
                ]
            }
        },
        {
            "id": "road-tertiary",
            "type": "line",
            "source": "openmaptiles",
            "source-layer": "transportation",
            "filter": ["==", ["get", "class"], "tertiary"],
            "minzoom": 10,
            "paint": {
                "line-color": "#ffee66",
                "line-width": [
                    "interpolate",
                    ["exponential", 1.5],
                    ["zoom"],
                    10,
                    0.2,
                    14,
                    1,
                    18,
                    4
                ]
            }
        },
        {
            "id": "road-street",
            "type": "line",
            "source": "openmaptiles",
            "source-layer": "transportation",
            "filter": [
                "in",
                ["get", "class"],
                ["literal", ["minor", "service", "track"]]
            ],
            "minzoom": 12,
            "paint": {
                "line-color": "#ffffff",
                "line-width": [
                    "interpolate",
                    ["exponential", 1.5],
                    ["zoom"],
                    12,
                    0.2,
                    16,
                    1,
                    18,
                    3
                ]
            }
        },
        {
            "id": "poi_label",
            "type": "symbol",
            "source": "openmaptiles",
            "source-layer": "poi",
            "minzoom": 13,
            "filter": ["all", ["==", "$type", "Point"], ["==", "rank", 1]],
            "layout": {
                "text-size": 12,
                "icon-image": "{class}",
                "text-offset": [0, 1.2],
                "text-anchor": "top",
                "text-field": "{name:latin}\n{name:nonlatin}",
                "icon-size": 1,
                "text-max-width": 8
            },
            "paint": {
                "text-color": "#ffffff",
                "text-halo-width": 1.5,
                "text-halo-color": "#000000"
            }
        },
        {
            "id": "road_major_label",
            "type": "symbol",
            "source": "openmaptiles",
            "source-layer": "transportation_name",
            "filter": [
                "all",
                ["==", "$type", "LineString"],
                ["!has", "name:en"]
            ],
            "minzoom": 12,
            "layout": {
                "symbol-placement": "line",
                "text-field": "{name:latin} {name:nonlatin}",
                "text-letter-spacing": 0.1,
                "text-rotation-alignment": "map",
                "text-size": {
                    "base": 1.4,
                    "stops": [
                        [10, 8],
                        [20, 14]
                    ]
                }
            },
            "paint": {
                "text-color": "#ffffff",
                "text-halo-color": "#000000",
                "text-halo-width": 2
            }
        },
        {
            "id": "road_major_label-en",
            "type": "symbol",
            "source": "openmaptiles",
            "source-layer": "transportation_name",
            "filter": [
                "all",
                ["==", "$type", "LineString"],
                ["has", "name:en"]
            ],
            "minzoom": 12,
            "layout": {
                "symbol-placement": "line",
                "text-field": "{name:en} {name:nonlatin}",
                "text-letter-spacing": 0.1,
                "text-rotation-alignment": "map",
                "text-size": {
                    "base": 1.4,
                    "stops": [
                        [10, 8],
                        [20, 14]
                    ]
                }
            },
            "paint": {
                "text-color": "#ffffff",
                "text-halo-color": "#000000",
                "text-halo-width": 2
            }
        },
        {
            "id": "place_label_other",
            "type": "symbol",
            "source": "openmaptiles",
            "source-layer": "place",
            "minzoom": 8,
            "filter": [
                "all",
                ["==", "$type", "Point"],
                ["all", ["!=", "class", "city"]],
                ["!has", "name:en"]
            ],
            "layout": {
                "text-anchor": "center",
                "text-field": "{name:latin}\n{name:nonlatin}",
                "text-max-width": 6,
                "text-size": {
                    "stops": [
                        [6, 10],
                        [12, 14]
                    ]
                },
                "visibility": "visible"
            },
            "paint": {
                "text-color": "#ffffff",
                "text-halo-color": "#000000",
                "text-halo-width": 2
            }
        },
        {
            "id": "place_label_other-en",
            "type": "symbol",
            "source": "openmaptiles",
            "source-layer": "place",
            "minzoom": 8,
            "filter": [
                "all",
                ["==", "$type", "Point"],
                ["all", ["!=", "class", "city"]],
                ["has", "name:en"]
            ],
            "layout": {
                "text-anchor": "center",
                "text-field": "{name:en}\n{name:nonlatin}",
                "text-max-width": 6,
                "text-size": {
                    "stops": [
                        [6, 10],
                        [12, 14]
                    ]
                },
                "visibility": "visible"
            },
            "paint": {
                "text-color": "#ffffff",
                "text-halo-color": "#000000",
                "text-halo-width": 2
            }
        },
        {
            "id": "place_label_city",
            "type": "symbol",
            "source": "openmaptiles",
            "source-layer": "place",
            "maxzoom": 16,
            "filter": [
                "all",
                ["==", "$type", "Point"],
                ["==", "class", "city"],
                ["!has", "name:en"]
            ],
            "layout": {
                "text-field": "{name:latin}\n{name:nonlatin}",
                "text-max-width": 10,
                "text-size": {
                    "stops": [
                        [3, 12],
                        [8, 16]
                    ]
                }
            },
            "paint": {
                "text-color": "#ffffff",
                "text-halo-color": "#000000",
                "text-halo-width": 2
            }
        },
        {
            "id": "place_label_city-en",
            "type": "symbol",
            "source": "openmaptiles",
            "source-layer": "place",
            "maxzoom": 16,
            "filter": [
                "all",
                ["==", "$type", "Point"],
                ["==", "class", "city"],
                ["has", "name:en"]
            ],
            "layout": {
                "text-field": "{name:en}\n{name:nonlatin}",
                "text-max-width": 10,
                "text-size": {
                    "stops": [
                        [3, 12],
                        [8, 16]
                    ]
                }
            },
            "paint": {
                "text-color": "#ffffff",
                "text-halo-color": "#000000",
                "text-halo-width": 2
            }
        },
        {
            "id": "country_label",
            "type": "symbol",
            "source": "openmaptiles",
            "source-layer": "place",
            "maxzoom": 12,
            "filter": [
                "all",
                ["==", "$type", "Point"],
                ["==", "class", "country"],
                ["!has", "name:en"]
            ],
            "layout": {
                "text-field": "{name:latin}\n{name:nonlatin}",
                "text-max-width": 10,
                "text-size": {
                    "stops": [
                        [3, 12],
                        [8, 22]
                    ]
                }
            },
            "paint": {
                "text-color": "#ffffff",
                "text-halo-color": "#000000",
                "text-halo-width": 2
            }
        },
        {
            "id": "country_label-en",
            "type": "symbol",
            "source": "openmaptiles",
            "source-layer": "place",
            "maxzoom": 12,
            "filter": [
                "all",
                ["==", "$type", "Point"],
                ["==", "class", "country"],
                ["has", "name:en"]
            ],
            "layout": {
                "text-field": "{name:en}\n{name:nonlatin}",
                "text-max-width": 10,
                "text-size": {
                    "stops": [
                        [3, 12],
                        [8, 22]
                    ]
                }
            },
            "paint": {
                "text-color": "#ffffff",
                "text-halo-color": "#000000",
                "text-halo-width": 2
            }
        }
    ],
    "terrain": {
        "source": "terrain",
        "exaggeration": 1.2
    }
}
