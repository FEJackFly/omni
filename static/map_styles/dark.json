{
    "version": 8,
    "name": "TrunkInsight Dark Globe",
    "metadata": {
        "description": "基于 OpenFreeMap 的暗色地球样式，模拟 Mapbox Standard Dark 效果"
    },
    "center": [116.38, 39.9],
    "zoom": 3,
    "bearing": 0,
    "pitch": 0,
    "sprite": "/sprites/ofm",
    "sources": {
        "openmaptiles": {
            "type": "vector",
            "url": "https://tiles.openfreemap.org/planet"
        }
    },
    "sky": {
        "sky-color": "#050510",
        "horizon-color": "#1a3a6a",
        "fog-color": "#0a0a1a",
        "fog-ground-blend": 0.3,
        "horizon-fog-blend": 0.5,
        "sky-horizon-blend": 0.3,
        "atmosphere-blend": 1
    },
    "layers": [
        {
            "id": "background",
            "type": "background",
            "paint": {
                "background-color": "#1a1a2e"
            }
        },
        {
            "id": "water",
            "type": "fill",
            "source": "openmaptiles",
            "source-layer": "water",
            "paint": {
                "fill-color": "#0d1b2a",
                "fill-opacity": 1
            }
        },
        {
            "id": "landcover-glacier",
            "type": "fill",
            "source": "openmaptiles",
            "source-layer": "landcover",
            "filter": ["==", ["get", "class"], "ice"],
            "paint": {
                "fill-color": "#2a2a4a",
                "fill-opacity": 0.7
            }
        },
        {
            "id": "landcover-wood",
            "type": "fill",
            "source": "openmaptiles",
            "source-layer": "landcover",
            "filter": ["==", ["get", "class"], "wood"],
            "paint": {
                "fill-color": "#1e3a1e",
                "fill-opacity": 0.4
            }
        },
        {
            "id": "landcover-grass",
            "type": "fill",
            "source": "openmaptiles",
            "source-layer": "landcover",
            "filter": ["==", ["get", "class"], "grass"],
            "paint": {
                "fill-color": "#1e3a1e",
                "fill-opacity": 0.3
            }
        },
        {
            "id": "landuse-residential",
            "type": "fill",
            "source": "openmaptiles",
            "source-layer": "landuse",
            "filter": ["==", ["get", "class"], "residential"],
            "paint": {
                "fill-color": "#252538",
                "fill-opacity": 0.6
            }
        },
        {
            "id": "landuse-commercial",
            "type": "fill",
            "source": "openmaptiles",
            "source-layer": "landuse",
            "filter": ["==", ["get", "class"], "commercial"],
            "paint": {
                "fill-color": "#2a2a40",
                "fill-opacity": 0.5
            }
        },
        {
            "id": "landuse-industrial",
            "type": "fill",
            "source": "openmaptiles",
            "source-layer": "landuse",
            "filter": ["==", ["get", "class"], "industrial"],
            "paint": {
                "fill-color": "#2a2535",
                "fill-opacity": 0.5
            }
        },
        {
            "id": "park",
            "type": "fill",
            "source": "openmaptiles",
            "source-layer": "park",
            "paint": {
                "fill-color": "#1a3020",
                "fill-opacity": 0.5
            }
        },
        {
            "id": "boundary-country",
            "type": "line",
            "source": "openmaptiles",
            "source-layer": "boundary",
            "filter": ["==", ["get", "admin_level"], 2],
            "paint": {
                "line-color": "#5a5a8a",
                "line-width": [
                    "interpolate",
                    ["linear"],
                    ["zoom"],
                    0,
                    0.5,
                    5,
                    1.5,
                    10,
                    2
                ],
                "line-opacity": 0.8
            }
        },
        {
            "id": "boundary-state",
            "type": "line",
            "source": "openmaptiles",
            "source-layer": "boundary",
            "filter": ["==", ["get", "admin_level"], 4],
            "minzoom": 3,
            "paint": {
                "line-color": "#5a5a8a",
                "line-width": 0.8,
                "line-dasharray": [3, 2],
                "line-opacity": 0.6
            }
        },
        {
            "id": "waterway",
            "type": "line",
            "source": "openmaptiles",
            "source-layer": "waterway",
            "paint": {
                "line-color": "#0d1b2a",
                "line-width": [
                    "interpolate",
                    ["linear"],
                    ["zoom"],
                    8,
                    0.5,
                    14,
                    2
                ]
            }
        },
        {
            "id": "road-motorway",
            "type": "line",
            "source": "openmaptiles",
            "source-layer": "transportation",
            "filter": ["==", ["get", "class"], "motorway"],
            "paint": {
                "line-color": "#4a3a5a",
                "line-width": [
                    "interpolate",
                    ["exponential", 1.5],
                    ["zoom"],
                    5,
                    0.5,
                    12,
                    3,
                    18,
                    15
                ],
                "line-opacity": 1
            }
        },
        {
            "id": "road-trunk",
            "type": "line",
            "source": "openmaptiles",
            "source-layer": "transportation",
