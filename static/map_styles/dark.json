            "id": "poi_label",
            "type": "symbol",
            "source": "openmaptiles",
            "source-layer": "poi",
            "minzoom": 13,
            "filter": ["all", ["==", "$type", "Point"], ["==", "rank", 1]],
            "layout": {
                "text-size": 12,
                "icon-image": "{class}",
                "text-offset": [0, 1.2],
                "text-anchor": "top",
                "text-field": "{name:latin}\n{name:nonlatin}",
                "icon-size": 1,
                "text-max-width": 8
            },
            "paint": {
                "text-color": "#cccccc",
                "text-halo-width": 1.5,
                "text-halo-color": "#1a1a2e"
            }
        },
